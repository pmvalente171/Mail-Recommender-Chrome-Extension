{
    "name": "Mail Recommender",
    "version": "0.1.0",
    "description": "AI-powered email autocomplete and recommendations",
    "permissions": ["storage"],
    "manifest_version": 3,
    "content_scripts": [
        {
            "matches": [
                "https://mail.google.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "background": {
        "service_worker": "ServiceWorker.js",
        "type": "module"
    },
    "action": {
        "default_popup": "index.html",
        "default_title": "Mail Recommender"
    },
    "icons": {
        "16": "logo192.png",
        "48": "logo192.png",
        "128": "logo192.png"
    }
}
